    ": si es $2, siempre $2. Nunca un día $10 y otro $50.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": ": if it's $2, always $2. Never $10 one day and $50 the next."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": ": si es $2, siempre $2. Nunca un día $10 y otro $50."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "- अगर $2 है, तो हमेशा $2। कभी एक दिन $10 और अगले दिन $50 नहीं।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": ": se é $2, sempre $2. Nunca $10 num dia e $50 no outro."

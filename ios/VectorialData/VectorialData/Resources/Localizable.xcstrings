    ". Escríbelo aquí y listo — tu cuenta queda creada.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": ". Type it here and you're in — your account is ready."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": ". Escríbelo aquí y listo — tu cuenta queda creada."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पर। उसे यहाँ लिखें — बस, आपका खाता तैयार।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": ". Digite aqui e pronto — sua conta está criada."
          }
        }

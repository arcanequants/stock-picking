    "Las oportunidades no avisan con tiempo. Deja que la app te avise en el momento justo — solo cuando hay algo que hacer, nunca spam.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Opportunities don't call ahead. Let the app alert you at the right moment — only when there's something to do, never spam."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las oportunidades no avisan con tiempo. Deja que la app te avise en el momento justo — solo cuando hay algo que hacer, nunca spam."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मौक़े पहले से बताकर नहीं आते। ऐप को सही समय पर बताने दें — सिर्फ़ तब जब कुछ करना हो, स्पैम कभी नहीं।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As oportunidades não avisam com antecedência. Deixe o app avisar na hora certa — só quando houver algo a fazer, nunca spam."
          }
        }
      }
    },

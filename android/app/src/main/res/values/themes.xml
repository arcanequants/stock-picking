<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark-only base theme. Compose draws the real UI; this just sets the
         window background and status-bar feel before the first frame. -->
    <style name="Theme.VectorialData" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:navigationBarColor">@color/app_background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>

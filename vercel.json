{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.vectorialdata.com"
        }
      ],
      "destination": "https://vectorialdata.com/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/snapshot",
      "schedule": "30 21 * * 1-5"
    },
    {
      "path": "/api/cron/event-scanner",
      "schedule": "45 21 * * 1-5"
    },
    {
      "path": "/api/cron/reset-usage",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/email-digest",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/cron/analytics-digest",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/analytics-digest?mode=weekly",
      "schedule": "15 14 * * 3"
    },
    {
      "path": "/api/cron/quant-lab-ingest",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/budget-reminder",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/trial-expiry",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/daily-briefing",
      "schedule": "30 12 * * *"
    },
    {
      "path": "/api/cron/signals-ingest",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/subscriber-briefing",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/stripe-sync-audit",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/dividend-scanner",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/pending-picks-digest",
      "schedule": "0 18 * * 5"
    },
    {
      "path": "/api/cron/hormuz-events-sync",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/seo-weekly",
      "schedule": "17 14 * * 1"
    }
  ]
}